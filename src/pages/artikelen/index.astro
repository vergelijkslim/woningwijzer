---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import { getCollection } from 'astro:content';
import '../../lib/affiliate-data';

const articles = (await getCollection('woningverbetering'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const breadcrumbs = [{ name: 'Home', href: '/' }, { name: 'Alle artikelen', href: '/artikelen/' }];
const typeLabels: Record<string, string> = { vergelijking: 'Vergelijking', review: 'Review', gids: 'Gids', regionaal: 'Regionaal' };
---

<BaseLayout title="Alle Artikelen over Woningverbetering" description="Overzicht van al onze artikelen over verbouwen, renoveren en verduurzamen.">
  <BreadcrumbSchema items={breadcrumbs} />
  <section class="category-hero"><div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">Home</a><span class="sep">/</span><span class="current">Alle artikelen</span></nav>
    <h1>Alle artikelen</h1>
    <p>Compleet overzicht van al onze woningverbetering content.</p>
    <div class="hero-stats">
      <div class="stat"><span class="stat-number">{articles.length}</span><span class="stat-label">Artikelen</span></div>
      <div class="stat-divider"></div>
      <div class="stat"><span class="stat-number">{articles.filter(a => a.data.type === 'gids').length}</span><span class="stat-label">Gidsen</span></div>
    </div>
  </div></section>
  <section class="articles"><div class="container"><div class="article-grid">
    {articles.map((article) => (
      <a href={`/woningverbetering/${article.id}/`} class="article-card">
        <div class="card-top"><span class={`badge ${article.data.type === 'gids' ? 'badge-green' : 'badge-amber'}`}>{typeLabels[article.data.type] || article.data.type}</span></div>
        <h2>{article.data.title}</h2>
        <p>{article.data.description}</p>
        <div class="card-footer">
          <span class="card-author">{article.data.author}</span>
          <span class="card-date">{article.data.publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>
        </div>
      </a>
    ))}
  </div></div></section>
</BaseLayout>

<style>
  .category-hero { background: linear-gradient(135deg, #064e3b 0%, #047857 50%, #059669 100%); padding: 3rem 0 3.5rem; color: #fff; }
  .breadcrumb { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; margin-bottom: 1.25rem; }
  .breadcrumb a { color: rgba(255,255,255,0.6); } .breadcrumb a:hover { color: #fff; }
  .breadcrumb .sep { color: rgba(255,255,255,0.4); } .breadcrumb .current { color: rgba(255,255,255,0.8); }
  .category-hero h1 { color: #fff; margin-bottom: 0.75rem; font-size: 2.25rem; }
  @media (min-width: 768px) { .category-hero { padding: 4rem 0 4.5rem; } .category-hero h1 { font-size: 2.75rem; } }
  .category-hero p { color: rgba(255,255,255,0.8); font-size: 1.0625rem; max-width: 560px; line-height: 1.7; }
  .hero-stats { display: flex; align-items: center; gap: 1.5rem; margin-top: 2rem; }
  .stat { text-align: center; } .stat-number { display: block; font-size: 1.5rem; font-weight: 700; font-family: var(--font-sans); color: #fff; }
  .stat-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: rgba(255,255,255,0.6); }
  .stat-divider { width: 1px; height: 32px; background: rgba(255,255,255,0.2); }
  .articles { padding: 2.5rem 0; }
  .article-grid { display: grid; gap: 1.5rem; }
  @media (min-width: 640px) { .article-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .article-grid { grid-template-columns: repeat(3, 1fr); } }
  .article-card { display: flex; flex-direction: column; padding: 1.5rem; border: 1px solid var(--color-border); border-radius: var(--radius-lg); color: var(--color-text); background: var(--color-bg); transition: all var(--transition-base); }
  .article-card:hover { text-decoration: none; box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--color-primary-light); }
  .card-top { margin-bottom: 0.75rem; }
  .article-card h2 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 600; line-height: 1.4; margin-bottom: 0.5rem; }
  .article-card p { color: var(--color-text-light); font-size: 0.875rem; line-height: 1.6; flex: 1; }
  .card-footer { display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; padding-top: 0.75rem; border-top: 1px solid var(--color-border-light); font-size: 0.8125rem; color: var(--color-text-muted); }
  .card-author { font-weight: 500; }
</style>
