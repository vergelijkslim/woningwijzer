---
import BaseLayout from '../../layouts/BaseLayout.astro';
import FAQSchema from '../../components/seo/FAQSchema.astro';
import BreadcrumbSchema from '../../components/seo/BreadcrumbSchema.astro';
import AffiliateButton from '../../components/AffiliateButton.astro';
import { getCollection, render } from 'astro:content';
import '../../lib/affiliate-data';

export async function getStaticPaths() {
  const articles = await getCollection('woningverbetering');
  return articles.map((article) => ({ params: { slug: article.id }, props: { article } }));
}

const { article } = Astro.props;
const { Content } = await render(article);
const { title, description, faq, affiliateLinks, publishDate, updatedDate, author, type } = article.data;
const readTime = Math.max(1, Math.ceil(article.body!.split(/\s+/).length / 250));
const typeLabels: Record<string, string> = { vergelijking: 'Vergelijking', review: 'Review', gids: 'Gids', regionaal: 'Regionaal' };
const breadcrumbs = [
  { name: 'Home', href: '/' },
  { name: 'Woningverbetering', href: '/artikelen/' },
  { name: title, href: `/woningverbetering/${article.id}/` },
];
const articleSchema = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description,
  datePublished: publishDate.toISOString(),
  ...(updatedDate && { dateModified: updatedDate.toISOString() }),
  author: { '@type': 'Organization', name: author },
  publisher: { '@type': 'Organization', name: 'Vergelijk Uw Renovatie' },
};
---

<BaseLayout title={title} description={description} ogType="article" structuredData={articleSchema}>
  <BreadcrumbSchema items={breadcrumbs} />
  {faq.length > 0 && <FAQSchema items={faq} />}

  <article class="article-page">
    <header class="article-header">
      <div class="container header-content">
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/">Home</a><span class="sep">/</span>
          <a href="/artikelen/">Artikelen</a><span class="sep">/</span>
          <span class="current">{title}</span>
        </nav>
        <span class="badge badge-primary">{typeLabels[type] || type}</span>
        <h1>{title}</h1>
        <p class="article-description">{description}</p>
        <div class="article-meta">
          <div class="author-info">
            <div class="author-avatar">{author.charAt(0)}</div>
            <div>
              <span class="author-name">{author}</span>
              <div class="meta-details">
                <time datetime={publishDate.toISOString()}>{publishDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'long', year: 'numeric' })}</time>
                {updatedDate && <span class="updated"> · Bijgewerkt {updatedDate.toLocaleDateString('nl-NL', { day: 'numeric', month: 'short', year: 'numeric' })}</span>}
                <span class="read-time"> · {readTime} min leestijd</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </header>

    <div class="container article-body">
      <div class="content-wrapper">
        <div class="prose"><Content /></div>
        {affiliateLinks.length > 0 && (
          <div class="cta-box">
            <h3>Direct vergelijken</h3>
            <p>Bekijk de beste aanbiedingen bij onze partners.</p>
            <div class="cta-buttons">{affiliateLinks.map((linkId) => (<AffiliateButton linkId={linkId} />))}</div>
          </div>
        )}
        {faq.length > 0 && (
          <section class="faq-section">
            <h2>Veelgestelde vragen</h2>
            {faq.map((item) => (
              <details class="faq-item">
                <summary><span>{item.question}</span><svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"/></svg></summary>
                <div class="faq-answer"><p>{item.answer}</p></div>
              </details>
            ))}
          </section>
        )}
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .article-header { background: var(--color-bg-alt); border-bottom: 1px solid var(--color-border); padding: 2rem 0 2.5rem; }
  .header-content { max-width: var(--content-width); }
  .breadcrumb { display: flex; align-items: center; gap: 0.375rem; font-size: 0.8125rem; margin-bottom: 1.25rem; flex-wrap: wrap; }
  .breadcrumb a { color: var(--color-text-muted); } .breadcrumb a:hover { color: var(--color-primary); }
  .breadcrumb .sep { color: var(--color-text-muted); }
  .breadcrumb .current { color: var(--color-text-light); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 200px; }
  .article-header .badge { margin-bottom: 0.75rem; }
  .article-header h1 { font-size: 2rem; margin-bottom: 0.75rem; max-width: 680px; }
  @media (min-width: 768px) { .article-header h1 { font-size: 2.5rem; } }
  .article-description { font-size: 1.125rem; color: var(--color-text-light); line-height: 1.7; max-width: 600px; margin-bottom: 1.5rem; }
  .article-meta { display: flex; align-items: center; }
  .author-info { display: flex; align-items: center; gap: 0.75rem; }
  .author-avatar { width: 40px; height: 40px; border-radius: 50%; background: var(--color-primary); color: #fff; display: flex; align-items: center; justify-content: center; font-weight: 600; font-size: 0.875rem; flex-shrink: 0; }
  .author-name { font-weight: 600; font-size: 0.9375rem; }
  .meta-details { font-size: 0.8125rem; color: var(--color-text-muted); margin-top: 0.125rem; }
  .updated { color: var(--color-primary); }
  .article-body { padding: 2.5rem 0; }
  .content-wrapper { max-width: var(--content-width); }
  .prose :global(h2) { margin-top: 2.5rem; margin-bottom: 0.875rem; padding-bottom: 0.5rem; border-bottom: 1px solid var(--color-border-light); }
  .prose :global(h3) { margin-top: 2rem; margin-bottom: 0.625rem; }
  .prose :global(p) { margin-bottom: 1.25rem; line-height: 1.8; }
  .prose :global(ul), .prose :global(ol) { margin-bottom: 1.25rem; padding-left: 1.5rem; }
  .prose :global(li) { margin-bottom: 0.375rem; line-height: 1.7; }
  .prose :global(strong) { font-weight: 600; color: var(--color-text); }
  .prose :global(blockquote) { border-left: 3px solid var(--color-primary); background: var(--color-bg-alt); padding: 1rem 1.25rem; margin: 1.5rem 0; border-radius: 0 var(--radius-md) var(--radius-md) 0; font-style: italic; color: var(--color-text-light); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.5rem 0; font-size: 0.9375rem; }
  .prose :global(th) { background: var(--color-bg-alt); font-weight: 600; text-align: left; padding: 0.75rem 1rem; border-bottom: 2px solid var(--color-border); font-size: 0.8125rem; text-transform: uppercase; letter-spacing: 0.03em; color: var(--color-text-light); }
  .prose :global(td) { padding: 0.75rem 1rem; border-bottom: 1px solid var(--color-border-light); }
  .prose :global(tr:hover) { background: var(--color-bg-alt); }
  .prose :global(a) { color: var(--color-primary); text-decoration: underline; text-decoration-color: var(--color-primary-light); text-underline-offset: 2px; }
  .cta-box { background: linear-gradient(135deg, #ecfdf5 0%, #f0fdf4 100%); border: 1px solid #a7f3d0; border-radius: var(--radius-xl); padding: 2rem; text-align: center; margin: 2.5rem 0; }
  .cta-box h3 { font-family: var(--font-sans); font-size: 1.125rem; margin-bottom: 0.375rem; }
  .cta-box p { color: var(--color-text-light); font-size: 0.9375rem; margin-bottom: 1.25rem; }
  .cta-buttons { display: flex; flex-wrap: wrap; justify-content: center; gap: 0.75rem; }
  .faq-section { margin-top: 3rem; padding-top: 2rem; border-top: 1px solid var(--color-border); }
  .faq-section h2 { margin-bottom: 1.25rem; }
  .faq-item { border: 1px solid var(--color-border); border-radius: var(--radius-lg); margin-bottom: 0.75rem; overflow: hidden; }
  .faq-item:hover { border-color: var(--color-primary-light); }
  .faq-item[open] { border-color: var(--color-primary); }
  .faq-item summary { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding: 1rem 1.25rem; cursor: pointer; font-weight: 600; font-size: 0.9375rem; list-style: none; }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary svg { flex-shrink: 0; color: var(--color-text-muted); transition: transform var(--transition-base); }
  .faq-item[open] summary svg { transform: rotate(180deg); }
  .faq-item[open] summary { border-bottom: 1px solid var(--color-border-light); }
  .faq-answer { padding: 1.25rem; background: var(--color-bg-alt); }
  .faq-answer p { line-height: 1.7; color: var(--color-text-light); }
</style>
