---
import BaseLayout from '../layouts/BaseLayout.astro';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'Gratis offertes aanvragen — Vergelijk Uw Renovatie',
  description: 'Ontvang gratis en vrijblijvend offertes van erkende aannemers voor jouw verbouwing, renovatie of verduurzaming.',
};

const steps = [
  {
    number: '1',
    title: 'Kies jouw renovatietype',
    description: 'Geef aan wat je wilt laten verbouwen of verduurzamen — van badkamer tot warmtepomp.',
  },
  {
    number: '2',
    title: 'Vind erkende vaklieden',
    description: 'Via onze partners vind je KvK-geverifieerde aannemers bij jou in de buurt. Aanvraag is gratis en vrijblijvend.',
  },
  {
    number: '3',
    title: 'Vergelijk offertes',
    description: 'Ontvang meerdere offertes en kies de beste prijs-kwaliteitsverhouding voor jouw situatie.',
  },
];

const categories = [
  {
    title: 'Verbouwing & renovatie',
    description: 'Badkamer, keuken, aanbouw, zolder of complete verbouwing. Erkende aannemers vergelijken.',
    features: ['Badkamer & keuken', 'Aanbouw & uitbouw', 'Zolder verbouwen', 'Complete renovatie'],
    url: 'https://www.offerteadviseur.nl/verbouwen/',
    cta: 'Gratis offertes aanvragen',
    featured: true,
    badge: 'Populairst',
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'Warmtepomp laten plaatsen',
    description: 'Vergelijk warmtepomp offertes van gecertificeerde installateurs. Inclusief ISDE-subsidie begeleiding.',
    features: ['Lucht-water warmtepomp', 'Hybride warmtepomp', 'ISDE-subsidie advies', 'Installatiecertificaat'],
    url: 'https://www.warmtepomp-weetjes.nl/warmtepomp-offertes/',
    cta: 'Warmtepomp offertes',
    featured: false,
    badge: null,
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  },
  {
    title: 'Isolatie & verduurzaming',
    description: 'Spouwmuurisolatie, dakisolatie, vloerisolatie en HR++ beglazing. Vergelijk subsidie-offertes.',
    features: ['Spouwmuurisolatie', 'Dakisolatie', 'Vloerisolatie', 'HR++ beglazing'],
    url: 'https://www.verbeterjehuis.nl/isolatie/',
    cta: 'Isolatie offertes vergelijken',
    featured: false,
    badge: null,
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>`,
  },
  {
    title: 'Aannemer vinden',
    description: 'Vind een betrouwbare aannemer via Werkspot. Bekijk reviews en vraag vrijblijvend offertes aan.',
    features: ['Geverifieerde reviews', 'Alle verbouwtypen', 'Direct contact', 'Vrijblijvend'],
    url: 'https://www.werkspot.nl/',
    cta: 'Aannemer vinden',
    featured: false,
    badge: null,
    icon: `<svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  },
];

const subsidies = [
  {
    name: 'ISDE-subsidie',
    description: 'Tot €1.875 terug op een erkende warmtepomp via de Investeringssubsidie Duurzame Energie.',
    href: '/woningverbetering/warmtepomp-kosten/',
  },
  {
    name: 'SEEH-subsidie',
    description: 'Subsidie voor spouwmuurisolatie, vloerisolatie en gevelisolatie — aanvragen via RVO.',
    href: '/woningverbetering/woning-isoleren-volgorde/',
  },
  {
    name: 'Gemeentelijke subsidie',
    description: 'Veel gemeenten bieden extra subsidie bovenop landelijke regelingen. Check verbeterjehuis.nl.',
    href: 'https://www.verbeterjehuis.nl/energiesubsidiewijzer/',
  },
];
---

<BaseLayout
  title="Gratis renovatie-offertes aanvragen"
  description="Ontvang gratis en vrijblijvend offertes van erkende aannemers voor verbouwing, warmtepomp, isolatie of renovatie. Inclusief subsidie-informatie."
  structuredData={structuredData}
>
  <!-- HERO -->
  <section class="page-hero">
    <div class="container hero-content">
      <span class="hero-badge">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Gratis offertes
      </span>
      <h1>Offerte aanvragen voor jouw verbouwing</h1>
      <p class="hero-sub">
        Vergelijk erkende aannemers en vaklieden bij jou in de buurt.
        Gratis, vrijblijvend en inclusief subsidie-begeleiding.
      </p>
      <div class="hero-trust">
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          Gratis & vrijblijvend
        </span>
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          KvK-geverifieerde aannemers
        </span>
        <span>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          Inclusief subsidie-advies
        </span>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="steps-section">
    <div class="container">
      <h2 class="section-title">Zo werkt het</h2>
      <div class="steps-grid">
        {steps.map((step) => (
          <div class="step-card">
            <div class="step-number">{step.number}</div>
            <h3>{step.title}</h3>
            <p>{step.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OFFER CATEGORIES -->
  <section class="categories-section">
    <div class="container">
      <h2 class="section-title">Kies jouw renovatietype</h2>
      <p class="section-sub">Selecteer de categorie die het beste past bij jouw project.</p>
      <div class="categories-grid">
        {categories.map((cat) => (
          <div class={`cat-card ${cat.featured ? 'cat-card--featured' : ''}`}>
            {cat.badge && <div class="cat-badge">{cat.badge}</div>}
            <div class="cat-icon"><Fragment set:html={cat.icon} /></div>
            <h3>{cat.title}</h3>
            <p>{cat.description}</p>
            <ul class="cat-features">
              {cat.features.map((f) => (
                <li>
                  <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                  {f}
                </li>
              ))}
            </ul>
            <a href={cat.url} class={cat.featured ? 'btn btn-cta' : 'btn btn-primary'} target="_blank" rel="noopener noreferrer sponsored">
              {cat.cta} →
            </a>
          </div>
        ))}
      </div>
      <p class="disclaimer">
        <small>* Wij ontvangen mogelijk een vergoeding wanneer je via onze links een aanvraag indient. Dit heeft geen invloed op onze beoordeling of het advies dat wij geven.</small>
      </p>
    </div>
  </section>

  <!-- SUBSIDIE INFO -->
  <section class="subsidie-section">
    <div class="container">
      <div class="subsidie-header">
        <span class="section-tag">Bespaar extra</span>
        <h2>Beschikbare subsidies in 2026</h2>
        <p>Combineer offertes met beschikbare subsidies voor maximale besparing.</p>
      </div>
      <div class="subsidie-grid">
        {subsidies.map((s) => (
          <a href={s.href} class="subsidie-card" rel={s.href.startsWith('http') ? 'noopener noreferrer' : undefined} target={s.href.startsWith('http') ? '_blank' : undefined}>
            <div class="subsidie-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            </div>
            <div>
              <h4>{s.name}</h4>
              <p>{s.description}</p>
            </div>
            <svg class="arrow" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TRUST / WHY US -->
  <section class="why-section">
    <div class="container">
      <div class="why-card">
        <div class="why-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <div class="why-text">
          <h3>Waarom via Vergelijk Uw Renovatie?</h3>
          <p>We werken uitsluitend samen met KvK-geverifieerde aannemers en gecertificeerde installateurs. Onze partners zijn geselecteerd op vakmanschap, klanttevredenheid en transparante prijsstelling. Aanvragen zijn altijd gratis en vrijblijvend — je zit nergens aan vast.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <div class="bottom-cta-inner">
        <h2>Liever eerst kosten vergelijken?</h2>
        <p>Bekijk onze onafhankelijke kostengidsen voordat je offertes aanvraagt.</p>
        <div class="bottom-cta-buttons">
          <a href="/gidsen/" class="btn btn-cta">Bekijk kostengidsen</a>
          <a href="/vergelijkingen/" class="btn btn-outline">Vergelijk kosten</a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO ── */
  .page-hero {
    background: linear-gradient(135deg, #064e3b 0%, #047857 40%, #059669 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .page-hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 50% 0%, rgba(167,243,208,0.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-content { position: relative; }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.375rem 1rem;
    background: rgba(167,243,208,0.18);
    border: 1px solid rgba(167,243,208,0.35);
    border-radius: 9999px;
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    color: #a7f3d0;
  }
  .page-hero h1 { color: #fff; font-size: 2.25rem; margin-bottom: 1.25rem; }
  .hero-sub { font-size: 1.0625rem; opacity: 0.85; line-height: 1.7; max-width: 560px; margin: 0 auto 2rem; }
  .hero-trust {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .hero-trust span {
    display: flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: rgba(255,255,255,0.8);
  }
  .hero-trust svg { opacity: 0.9; flex-shrink: 0; }
  @media (min-width: 768px) {
    .page-hero { padding: 6rem 0 7rem; }
    .page-hero h1 { font-size: 3rem; }
  }

  /* ── STEPS ── */
  .steps-section { padding: 4rem 0; background: var(--color-bg-alt); }
  .section-title { text-align: center; margin-bottom: 0.5rem; }
  .section-sub { text-align: center; color: var(--color-text-light); margin-bottom: 2.5rem; font-size: 1rem; }
  .section-tag {
    display: block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    text-align: center;
  }
  .steps-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) { .steps-grid { grid-template-columns: repeat(3, 1fr); } }
  .step-card { text-align: center; padding: 2rem 1.5rem; }
  .step-number {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 1.25rem;
    font-weight: 700;
    font-family: var(--font-sans);
    margin-bottom: 1rem;
  }
  .step-card h3 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 600; margin-bottom: 0.5rem; }
  .step-card p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.6; }

  /* ── CATEGORIES ── */
  .categories-section { padding: 4.5rem 0; }
  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 0.5rem;
  }
  @media (min-width: 640px) { .categories-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1200px) { .categories-grid { grid-template-columns: repeat(4, 1fr); } }
  .cat-card {
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    padding: 2rem;
    background: #fff;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
    position: relative;
    transition: all var(--transition-base);
  }
  .cat-card:hover { box-shadow: var(--shadow-lg); transform: translateY(-2px); }
  .cat-card--featured { border-color: var(--color-primary); box-shadow: 0 0 0 1px var(--color-primary); }
  .cat-card--featured:hover { box-shadow: 0 0 0 1px var(--color-primary), var(--shadow-lg); }
  .cat-badge {
    position: absolute;
    top: -12px;
    left: 1.5rem;
    padding: 0.25rem 0.875rem;
    background: var(--color-primary);
    color: #fff;
    border-radius: 9999px;
    font-size: 0.75rem;
    font-weight: 700;
  }
  .cat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    background: var(--color-primary-light);
    color: var(--color-primary);
    flex-shrink: 0;
  }
  .cat-card h3 { font-family: var(--font-sans); font-size: 1.0625rem; font-weight: 700; }
  .cat-card > p { color: var(--color-text-light); font-size: 0.9rem; line-height: 1.55; flex: 1; }
  .cat-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .cat-features li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    color: var(--color-text-light);
  }
  .cat-features svg { color: var(--color-primary); flex-shrink: 0; }
  .cat-card .btn { width: 100%; justify-content: center; margin-top: 0.25rem; }
  .disclaimer { text-align: center; margin-top: 2rem; color: var(--color-text-muted); font-size: 0.8125rem; }

  /* ── SUBSIDIES ── */
  .subsidie-section { padding: 4rem 0; background: var(--color-bg-alt); }
  .subsidie-header { text-align: center; margin-bottom: 2.5rem; }
  .subsidie-header h2 { margin-bottom: 0.5rem; }
  .subsidie-header p { color: var(--color-text-light); }
  .subsidie-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
    max-width: 820px;
    margin: 0 auto;
  }
  .subsidie-card {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: #fff;
    color: var(--color-text);
    text-decoration: none;
    transition: all var(--transition-base);
  }
  .subsidie-card:hover { text-decoration: none; box-shadow: var(--shadow-md); border-color: var(--color-primary-light); }
  .subsidie-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    min-width: 48px;
    border-radius: var(--radius-md);
    background: var(--color-primary-light);
    color: var(--color-primary);
  }
  .subsidie-card div { flex: 1; }
  .subsidie-card h4 { font-family: var(--font-sans); font-size: 1rem; font-weight: 700; margin-bottom: 0.25rem; }
  .subsidie-card p { font-size: 0.875rem; color: var(--color-text-light); line-height: 1.5; }
  .subsidie-card .arrow { color: var(--color-primary); flex-shrink: 0; }

  /* ── WHY ── */
  .why-section { padding: 3rem 0; }
  .why-card {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 2rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    background: #fff;
    max-width: 820px;
    margin: 0 auto;
  }
  @media (min-width: 640px) { .why-card { flex-direction: row; align-items: center; gap: 2rem; padding: 2rem 2.5rem; } }
  .why-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 64px;
    height: 64px;
    min-width: 64px;
    border-radius: var(--radius-xl);
    background: var(--color-primary-light);
    color: var(--color-primary);
  }
  .why-text h3 { font-family: var(--font-sans); font-size: 1.125rem; font-weight: 700; margin-bottom: 0.5rem; }
  .why-text p { color: var(--color-text-light); font-size: 0.9375rem; line-height: 1.65; }

  /* ── BOTTOM CTA ── */
  .bottom-cta { padding: 5rem 0; background: linear-gradient(135deg, #064e3b 0%, #047857 100%); color: #fff; }
  .bottom-cta-inner { text-align: center; max-width: 560px; margin: 0 auto; }
  .bottom-cta h2 { color: #fff; font-size: 2rem; margin-bottom: 0.875rem; }
  .bottom-cta p { color: rgba(255,255,255,0.8); font-size: 1.0625rem; margin-bottom: 2rem; line-height: 1.65; }
  .bottom-cta-buttons { display: flex; justify-content: center; gap: 1rem; flex-wrap: wrap; }
  .btn-outline {
    background: transparent;
    color: #fff;
    border: 2px solid rgba(255,255,255,0.35);
    border-radius: var(--radius-lg);
  }
  .btn-outline:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.65); color: #fff; text-decoration: none; }
</style>
