---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import '../lib/affiliate-data';

const structuredData = {
  '@context': 'https://schema.org', '@type': 'WebSite',
  name: 'Vergelijk Uw Renovatie', url: Astro.site?.href,
  description: 'Onafhankelijke gids voor verbouwen, renoveren en verduurzamen in Nederland', inLanguage: 'nl',
};

const allArticles = (await getCollection('woningverbetering'))
  .filter((a) => !a.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const featured = allArticles.filter((a) => a.data.featured).slice(0, 3);
const latest = allArticles.slice(0, 6);
const gidsen = allArticles.filter((a) => a.data.type === 'gids');
const vergelijkingen = allArticles.filter((a) => a.data.type === 'vergelijking');

const typeLabels: Record<string, string> = { vergelijking: 'Vergelijking', review: 'Review', gids: 'Gids', regionaal: 'Regionaal' };

const categories = [
  {
    title: 'Badkamer & Keuken',
    description: 'Kosten, tips en aannemers vergelijken voor badkamer- en keukenrenovatie.',
    href: '/vergelijkingen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18M3 6a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2"/><path d="M3 6V4a1 1 0 0 1 1-1h2a1 1 0 0 1 1 1v2"/></svg>`,
  },
  {
    title: 'Dak & Gevel',
    description: 'Dakpannen, dakkapellen, gevelisolatie en kozijnen — complete kostenoverzichten.',
    href: '/vergelijkingen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  },
  {
    title: 'Verduurzaming',
    description: 'Warmtepomp, zonnepanelen, vloerverwarming en isolatie. Bespaar energie en kosten.',
    href: '/gidsen/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>`,
  },
  {
    title: 'Gratis offertes',
    description: 'Ontvang gratis en vrijblijvend offertes van erkende aannemers in jouw regio.',
    href: '/offerte/',
    icon: `<svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
    highlight: true,
  },
];
---

<BaseLayout
  title="Vergelijk Uw Renovatie"
  description="Onafhankelijk advies over verbouwen, renoveren en verduurzamen. Vergelijk kosten, vind aannemers en bespaar met subsidies."
  structuredData={structuredData}
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <span class="hero-eyebrow">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
          Renovatiewijzer
        </span>
        <h1>Verbouwen zonder<br /><em>verrassingen</em></h1>
        <p class="hero-sub">
          Onafhankelijke kosten­overzichten, eerlijk aannemers­advies en gratis offertes.
          Van badkamer tot complete verduurzaming.
        </p>
        <div class="hero-stats">
          <div class="stat">
            <span class="stat-num">{allArticles.length}+</span>
            <span class="stat-label">Gidsen & vergelijkingen</span>
          </div>
          <div class="stat">
            <span class="stat-num">€2.000</span>
            <span class="stat-label">Gem. subsidie beschikbaar</span>
          </div>
          <div class="stat">
            <span class="stat-num">100%</span>
            <span class="stat-label">Onafhankelijk</span>
          </div>
        </div>
        <div class="hero-actions">
          <a href="/offerte/" class="btn btn-cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Gratis offertes aanvragen
          </a>
          <a href="/gidsen/" class="btn btn-ghost">Bekijk kostengidsen &rarr;</a>
        </div>
      </div>
      <div class="hero-visual" aria-hidden="true">
        <!-- House renovation illustration -->
        <svg viewBox="0 0 320 340" fill="none" xmlns="http://www.w3.org/2000/svg" class="house-illustration">
          <!-- Shadow -->
          <ellipse cx="160" cy="325" rx="100" ry="10" fill="rgba(255,255,255,0.06)"/>
          <!-- House body -->
          <rect x="60" y="160" width="200" height="155" rx="4" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <!-- Roof -->
          <polygon points="40,165 160,60 280,165" fill="rgba(255,255,255,0.15)" stroke="rgba(255,255,255,0.3)" stroke-width="2"/>
          <!-- Chimney -->
          <rect x="195" y="80" width="22" height="48" rx="3" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"/>
          <!-- Door -->
          <rect x="135" y="245" width="50" height="70" rx="4" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
          <circle cx="179" cy="283" r="3" fill="rgba(255,255,255,0.5)"/>
          <!-- Windows -->
          <rect x="78" y="185" width="50" height="40" rx="4" fill="rgba(167,243,208,0.2)" stroke="rgba(167,243,208,0.5)" stroke-width="1.5"/>
          <line x1="103" y1="185" x2="103" y2="225" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <line x1="78" y1="205" x2="128" y2="205" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <rect x="192" y="185" width="50" height="40" rx="4" fill="rgba(167,243,208,0.2)" stroke="rgba(167,243,208,0.5)" stroke-width="1.5"/>
          <line x1="217" y1="185" x2="217" y2="225" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <line x1="192" y1="205" x2="242" y2="205" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <!-- Solar panel on roof -->
          <rect x="80" y="115" width="55" height="35" rx="3" fill="rgba(167,243,208,0.25)" stroke="rgba(167,243,208,0.7)" stroke-width="1.5" transform="rotate(-30 107 132)"/>
          <line x1="75" y1="118" x2="130" y2="100" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <line x1="80" y1="127" x2="135" y2="109" stroke="rgba(167,243,208,0.4)" stroke-width="1"/>
          <!-- Garden/path -->
          <rect x="148" y="315" width="24" height="10" rx="2" fill="rgba(255,255,255,0.15)"/>
        </svg>
        <!-- Floating badges -->
        <div class="float-badge float-badge-1">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="#047857"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01" stroke="#047857" stroke-width="2" fill="none"/></svg>
          <span>ISDE subsidie 2026</span>
        </div>
        <div class="float-badge float-badge-2">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
          <span>Erkende aannemers</span>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST BAR -->
  <section class="trust-bar">
    <div class="container">
      <div class="trust-items">
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          <span>Onafhankelijk advies</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          <span>Erkende vaklieden</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
          <span>Gratis offertes</span>
        </div>
        <div class="trust-divider"></div>
        <div class="trust-item">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
          <span>Bijgewerkt april 2026</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CATEGORIES -->
  <section class="categories-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Onderwerpen</span>
        <h2>Waar wil je mee beginnen?</h2>
        <p>Van kleine opfrisbeurt tot complete verduurzaming — wij helpen je de juiste keuze maken.</p>
      </div>
      <div class="categories-grid">
        {categories.map((cat) => (
          <a href={cat.href} class={`cat-card${cat.highlight ? ' cat-card--highlight' : ''}`}>
            <div class="cat-icon"><Fragment set:html={cat.icon} /></div>
            <h3>{cat.title}</h3>
            <p>{cat.description}</p>
            <span class="cat-cta">{cat.highlight ? 'Gratis aanvragen →' : 'Bekijk gidsen →'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- COST ESTIMATOR TEASER -->
  <section class="estimator-section">
    <div class="container">
      <div class="estimator-card">
        <div class="estimator-text">
          <span class="section-tag">Handige tool</span>
          <h2>Wat gaat jouw verbouwing kosten?</h2>
          <p>Gebruik onze kostencalculator voor een eerste indicatie van jouw renovatiebudget — inclusief materialen, arbeidskosten en leges.</p>
          <a href="/offerte/" class="btn btn-cta">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
            Vraag gratis offertes aan
          </a>
        </div>
        <div class="estimator-highlights">
          <div class="highlight-item">
            <span class="highlight-num">€4.000–€8.000</span>
            <span class="highlight-label">Badkamer renovatie</span>
          </div>
          <div class="highlight-item">
            <span class="highlight-num">€8.000–€25.000</span>
            <span class="highlight-label">Warmtepomp installatie</span>
          </div>
          <div class="highlight-item">
            <span class="highlight-num">€5.000–€15.000</span>
            <span class="highlight-label">Dakkapel plaatsen</span>
          </div>
          <div class="highlight-item">
            <span class="highlight-num">€3.000–€7.000</span>
            <span class="highlight-label">Keuken renovatie</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED ARTICLES -->
  {featured.length > 0 && (
    <section class="featured-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Uitgelicht</span>
          <h2>Populairste gidsen</h2>
          <p>Onze meest gelezen artikelen over verbouwen en renoveren in Nederland.</p>
        </div>
        <div class="featured-grid">
          {featured.map((article, i) => (
            <a href={`/woningverbetering/${article.id}/`} class={`featured-card${i === 0 ? ' featured-card--main' : ''}`}>
              <span class={`badge ${article.data.type === 'gids' ? 'badge-primary' : 'badge-amber'}`}>{typeLabels[article.data.type] || 'Artikel'}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="read-more">Lees gids →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- LATEST ARTICLES -->
  {latest.length > 0 && (
    <section class="latest-section">
      <div class="container">
        <div class="section-header">
          <span class="section-tag">Alle artikelen</span>
          <h2>Recente gidsen & vergelijkingen</h2>
          <p>Regelmatig bijgewerkt met actuele prijzen en subsidie-informatie.</p>
        </div>
        <div class="latest-grid">
          {latest.map((article) => (
            <a href={`/woningverbetering/${article.id}/`} class="latest-card">
              <span class={`badge ${article.data.type === 'gids' ? 'badge-green' : 'badge-amber'}`}>{typeLabels[article.data.type] || article.data.type}</span>
              <h3>{article.data.title}</h3>
              <p>{article.data.description}</p>
              <span class="read-more">Lees meer →</span>
            </a>
          ))}
        </div>
        <div class="view-all"><a href="/artikelen/" class="btn btn-primary">Bekijk alle artikelen</a></div>
      </div>
    </section>
  )}

  <!-- METHODOLOGY / TRUST -->
  <section class="methodology-section">
    <div class="container">
      <div class="methodology-card">
        <div class="methodology-icon">
          <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
        </div>
        <div class="methodology-text">
          <h3>Zo beoordelen wij aannemers</h3>
          <p>We toetsen elke aannemer op 6 criteria: vakmanschap, prijs-kwaliteit, communicatie, garantie, referenties en KvK-verificatie. Alleen erkende vaklieden komen in aanmerking.</p>
        </div>
        <a href="/zo-vergelijken-wij/" class="btn btn-primary">Onze methode</a>
      </div>
    </div>
  </section>

  <!-- BOTTOM CTA -->
  <section class="bottom-cta">
    <div class="container">
      <div class="bottom-cta-inner">
        <h2>Klaar om je verbouwing te starten?</h2>
        <p>Ontvang gratis en vrijblijvend offertes van erkende aannemers in jouw regio.</p>
        <div class="bottom-cta-buttons">
          <a href="/offerte/" class="btn btn-cta">Gratis offertes aanvragen</a>
          <a href="/vergelijkingen/" class="btn btn-outline">Vergelijk kosten</a>
        </div>
        <p class="disclaimer">
          <small>Onafhankelijk &middot; Geen voorkeurspositie op basis van commissie &middot; Bijgewerkt april 2026</small>
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, #064e3b 0%, #047857 40%, #059669 70%, #10b981 100%);
    color: #fff;
    padding: 4rem 0 5rem;
    overflow: hidden;
    position: relative;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at 60% 0%, rgba(167,243,208,0.12) 0%, transparent 65%);
    pointer-events: none;
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    position: relative;
  }
  @media (min-width: 900px) {
    .hero { padding: 6rem 0 7rem; }
    .hero-inner { grid-template-columns: 1fr 380px; gap: 4rem; }
  }
  .hero-eyebrow {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.75);
    margin-bottom: 1.25rem;
  }
  .hero h1 {
    color: #fff;
    font-size: 2.5rem;
    margin-bottom: 1.25rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
  }
  .hero h1 em { font-style: normal; color: #6ee7b7; }
  @media (min-width: 768px) { .hero h1 { font-size: 3.25rem; } }
  .hero-sub {
    font-size: 1.0625rem;
    opacity: 0.88;
    line-height: 1.7;
    max-width: 520px;
    margin-bottom: 2rem;
  }
  .hero-stats {
    display: flex;
    gap: 2rem;
    margin-bottom: 2.25rem;
    flex-wrap: wrap;
  }
  .stat { display: flex; flex-direction: column; }
  .stat-num { font-size: 1.5rem; font-weight: 800; color: #fff; line-height: 1; }
  .stat-label { font-size: 0.75rem; color: rgba(255,255,255,0.65); margin-top: 0.2rem; }
  .hero-actions { display: flex; gap: 0.875rem; flex-wrap: wrap; align-items: center; }
  .btn-ghost {
    background: rgba(255,255,255,0.12);
    color: #fff;
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: var(--radius-lg);
  }
  .btn-ghost:hover { background: rgba(255,255,255,0.2); color: #fff; text-decoration: none; }

  /* Hero illustration */
  .hero-visual {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    display: none;
  }
  @media (min-width: 900px) { .hero-visual { display: flex; } }
  .house-illustration { width: 100%; max-width: 320px; filter: drop-shadow(0 20px 40px rgba(0,0,0,0.2)); }
  .float-badge {
    position: absolute;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.95);
    color: #0f1a0f;
    font-size: 0.8125rem;
    font-weight: 600;
    padding: 0.5rem 0.875rem;
    border-radius: 9999px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.12);
    white-space: nowrap;
  }
  .float-badge-1 { top: 20%; right: -10%; }
  .float-badge-2 { bottom: 22%; left: -8%; }

  /* ── TRUST BAR ── */
  .trust-bar {
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    padding: 1.125rem 0;
  }
  .trust-items {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .trust-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-text-light);
  }
  .trust-item svg { color: var(--color-primary); flex-shrink: 0; }
  .trust-divider { width: 1px; height: 18px; background: var(--color-border); display: none; }
  @media (min-width: 640px) { .trust-divider { display: block; } .trust-items { gap: 2rem; } }

  /* ── CATEGORIES ── */
  .categories-section { padding: 4.5rem 0; }
  .section-header { text-align: center; margin-bottom: 2.5rem; }
  .section-tag {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 0.625rem;
  }
  .section-header h2 { margin-bottom: 0.5rem; }
  .section-header p { color: var(--color-text-light); font-size: 1.0625rem; max-width: 560px; margin: 0 auto; }
  .categories-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  @media (min-width: 640px) { .categories-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .categories-grid { grid-template-columns: repeat(4, 1fr); } }
  .cat-card {
    display: flex;
    flex-direction: column;
    padding: 1.75rem;
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-xl);
    color: var(--color-text);
    background: var(--color-bg);
    transition: all var(--transition-base);
    text-decoration: none;
  }
  .cat-card:hover {
    text-decoration: none;
    box-shadow: var(--shadow-lg);
    transform: translateY(-3px);
    border-color: var(--color-primary-light);
  }
  .cat-card--highlight {
    background: var(--color-bg-alt);
    border-color: var(--color-primary-light);
  }
  .cat-card--highlight:hover { border-color: var(--color-primary); }
  .cat-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: var(--radius-lg);
    background: var(--color-primary-light);
    color: var(--color-primary);
    margin-bottom: 1.125rem;
    flex-shrink: 0;
  }
  .cat-card h3 {
    font-family: var(--font-sans);
    font-size: 1.0625rem;
    font-weight: 700;
    margin-bottom: 0.4rem;
  }
  .cat-card p {
    color: var(--color-text-light);
    font-size: 0.9rem;
    line-height: 1.55;
    flex: 1;
    margin-bottom: 1rem;
  }
  .cat-cta { font-size: 0.875rem; font-weight: 600; color: var(--color-primary); }
