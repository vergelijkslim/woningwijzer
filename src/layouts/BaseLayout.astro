---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AffiliateDisclosure from '../components/AffiliateDisclosure.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
  structuredData?: object | object[];
}

const {
  title, description,
  canonical = Astro.url.href,
  ogImage = '/images/og-default.jpg',
  ogType = 'website',
  noindex = false,
  structuredData,
} = Astro.props;

const siteName = 'Vergelijk Uw Renovatie';
const fullTitle = title === siteName ? title : `${title} | ${siteName}`;
---

<!doctype html>
<html lang="nl">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  {noindex && <meta name="robots" content="noindex,nofollow" />}
  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:url" content={canonical} />
  <meta property="og:locale" content="nl_NL" />
  <meta property="og:site_name" content={siteName} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <!-- Daisycon media verificatie -->
  <meta name="3d8ee0db76a4993" content="00cc525d2db94376fe9c14baf1cb76b8" />

  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Lora:ital,wght@0,400;0,600;0,700;1,400&display=swap" />

  <!-- TradeTracker site verificatie -->
  <meta name="tt-site-verification" content="0afafdd5c0c876d7ee7e78407ace124fe2bcf04a" />

  <!-- GA4: activated when PUBLIC_GA4_ID env var is set (e.g. G-XXXXXXXXXX) -->
  {import.meta.env.PUBLIC_GA4_ID && (
    <>
      <script async src={`https://www.googletagmanager.com/gtag/js?id=${import.meta.env.PUBLIC_GA4_ID}`}></script>
      <script define:vars={{ ga4Id: import.meta.env.PUBLIC_GA4_ID }}>
        window.dataLayer = window.dataLayer || [];
        function gtag() { dataLayer.push(arguments); }
        gtag('js', new Date());
        gtag('config', ga4Id, { anonymize_ip: true });
        document.addEventListener('DOMContentLoaded', function () {
          document.querySelectorAll('a[data-affiliate-id], a[rel~="sponsored"]').forEach(function (el) {
            el.addEventListener('click', function () {
              gtag('event', 'affiliate_click', { affiliate_id: el.getAttribute('data-affiliate-id') || 'unknown', affiliate_network: el.getAttribute('data-affiliate-network') || 'unknown', page_path: window.location.pathname, link_url: el.href });
            });
          });
          document.querySelectorAll('a[target="_blank"]').forEach(function (el) {
            if (!el.hasAttribute('data-affiliate-id')) {
              el.addEventListener('click', function () { gtag('event', 'outbound_click', { link_url: el.href, page_path: window.location.pathname }); });
            }
          });
        });
      </script>
    </>
  )}
  {structuredData && (
    <script type="application/ld+json" set:html={JSON.stringify(Array.isArray(structuredData) ? structuredData : [structuredData])} />
  )}
  <style>
    .page-wrapper { display: flex; flex-direction: column; min-height: 100vh; }
    main { flex: 1; }
  </style>
</head>
<body>
  <div class="page-wrapper">
    <Header />
    <main><slot /></main>
    <AffiliateDisclosure />
    <Footer />
    <CookieConsent />
  </div>

  <!-- Begin TradeTracker SuperTag Code -->
  <script is:inline>
  var _TradeTrackerTagOptions = { t: 'a', s: '509223', chk: '4f90a60e8af05a914a280ba69c4d0503', overrideOptions: {} };
  (function() {var tt = document.createElement('script'), s = document.getElementsByTagName('script')[0]; tt.setAttribute('type', 'text/javascript'); tt.setAttribute('src', (document.location.protocol == 'https:' ? 'https' : 'http') + '://tm.tradetracker.net/tag?t=' + _TradeTrackerTagOptions.t + '&s=' + _TradeTrackerTagOptions.s + '&chk=' + _TradeTrackerTagOptions.chk); s.parentNode.insertBefore(tt, s);})();
  </script>
  <!-- End TradeTracker SuperTag Code -->
</body>
</html>
